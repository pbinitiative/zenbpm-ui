{
  "name": "zenbpm-ui",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "pnpm generate:api && node scripts/generate-i18n-types.mjs",
    "predev": "pnpm prebuild",
    "dev": "vite",
    "dev:mocks": "pnpm dev --mode mocks",
    "dev:live": "pnpm dev --mode live",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "check": "pnpm lint && pnpm typecheck",
    "preview": "vite preview",
    "generate:validation-schemas": "node scripts/generate-openapi-validation-schemas.mjs",
    "generate:api": "pnpm generate:validation-schemas && orval",
    "generate:i18n-types": "node scripts/generate-i18n-types.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@bpmn-io/form-js": "^1.21.3",
    "@bpmn-io/properties-panel": "^3.44.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@lezer/highlight": "^1.2.3",
    "@lezer/xml": "^1.0.6",
    "@monaco-editor/react": "^4.7.0",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "bpmn-js": "^18.18.0",
    "bpmn-js-properties-panel": "^5.58.0",
    "camunda-bpmn-js": "^5.28.0",
    "camunda-bpmn-js-behaviors": "^1.16.1",
    "camunda-bpmn-moddle": "^7.0.1",
    "dmn-js": "^17.8.1",
    "dmn-js-properties-panel": "^3.11.1",
    "dotenv": "^17.4.2",
    "i18next": "^26.3.1",
    "json-bigint": "^1.0.0",
    "oidc-client-ts": "^3.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@redocly/cli": "^2.31.6",
    "@storybook/addon-a11y": "^10.4.2",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-storybook": "^10.4.2",
    "globals": "^17.6.0",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.13.0",
    "openapi3-ts": "^4.6.0",
    "orval": "^8.16.0",
    "storybook": "^10.4.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  },
  "pnpm": {
    "overrides": {
      "preact": "10.15.1"
    }
  }
}
